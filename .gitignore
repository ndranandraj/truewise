# Data working sets (regenerated by the pipeline — do not commit)
/data/
*.parquet
*.duckdb
*.duckdb.wal

# Secrets
.env

# Python
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/

# FUSE mount artifacts (must never be committed)
.fuse_hidden*
**/.fuse_hidden*

# OS / editor
.DS_Store
.idea/
.vscode/

# Planning / internal strategy & goal docs — kept LOCAL, never published to GitHub
/PLAN.md
/HANDOFF.md
/CLAUDE.md
/Truewise - Project Plan v2 (Reputation-First).md
/Truewise - Iteration Plan & Checklist.md
/Truewise - Education Data Platform Plan.pdf
/College ROI Analyzer - Project Plan.pdf
/docs/IMPACT_LOG.md
/docs/GO_PUBLIC.md
# Internal review / design working files, never publish
truewise-authenticity-review*.md
Truewise.dev design review.zip
truewise-design-improvement-plan.md

# FVT Monitor: keep provenance + the compact dated snapshot, ignore the bulky raw dumps
archive/**/*.zip
archive/**/*.csv

# ...but DO keep the compact dated Monitor snapshots
!archive/**/*.parquet

# Bundled dataset inside the pip package (tracked)
!packages/**/*.parquet
/docs/GO_PUBLISH.md

# Python build artifacts inside packages
packages/**/build/
packages/**/dist/
packages/**/*.egg-info/

# Generated site data is built at deploy time, not committed (kept lean).
site/value-check/data/
site/careers/data/
site/k12/data/
site/data/value_check_summary.json
# Downloadable datasets are copied into site/data/ at deploy time (already ignored by *.parquet):
site/data/*.parquet
# ...but the compact parquet build-source IS tracked:
!published/*.parquet
/docs/GO_DEPLOY.md
